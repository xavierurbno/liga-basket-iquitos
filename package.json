{
  "name": "liga-basket-iquitos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true}); console.log('Removed .next')\"",
    "sync:dev-manifest": "node scripts/prepare-webpack-dev.mjs",
    "dev": "node scripts/prepare-webpack-dev.mjs && next dev -p 3001 --webpack",
    "dev:turbo": "next dev -p 3001 --turbopack",
    "kill:dev-port": "node scripts/kill-dev-port.mjs",
    "db:migrate:0020": "node scripts/apply-migration-0020.mjs",
    "dev:clean": "node scripts/kill-dev-port.mjs && npm run clean && npm run dev",
    "dev:fresh": "npm run clean && npm run build && npm run dev",
    "build": "next build",
    "build:vercel": "npm run env:verify:strict && npm run build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate:dev": "node scripts/db-migrate.mjs development",
    "db:migrate:prod": "node scripts/db-migrate.mjs production",
    "db:apply-sql:prod": "node scripts/apply-sql-prod.mjs",
    "db:validate:manifest": "node scripts/validate-migration-manifest.mjs",
    "db:audit:access": "node scripts/audit-db-access.mjs",
    "db:bootstrap:dev": "node scripts/db-apply-all.mjs development",
    "db:seed:dev-league": "node scripts/seed-dev-league.mjs",
    "db:seed:dev-club": "node scripts/seed-dev-club.mjs",
    "db:seed:dev": "node scripts/seed-dev-league.mjs && node scripts/seed-dev-club.mjs",
    "db:bootstrap:prod": "node scripts/db-apply-all.mjs production",
    "db:verify:dev": "node scripts/db-verify.mjs development",
    "db:verify:prod": "node scripts/db-verify.mjs production",
    "db:dev:drizzle-migrations": "node scripts/dev-check-drizzle-migrations.mjs",
    "generate": "npm run db:generate",
    "migrate": "npm run db:migrate:dev",
    "push": "drizzle-kit push",
    "studio": "drizzle-kit studio",
    "env:verify": "node scripts/phase3-env-check.mjs",
    "env:verify:strict": "node scripts/phase3-env-check.mjs --strict",
    "test": "node --experimental-strip-types --test src/lib/tournaments/score-quarters.test.ts src/lib/auth/assignable-roles.test.ts src/lib/auth/read-user-role.test.ts src/lib/auth/extract-club-id-from-args.test.ts src/lib/auth/delegate-club-scope.test.ts src/lib/auth/treasury-scope.test.ts src/lib/busqueda365/busqueda365-league-scope.test.ts src/lib/db/public-read-guards.test.ts src/lib/validation/entity-validation-token.test.ts src/lib/storage/storage-upload-guards.test.ts src/lib/security/rate-limit.test.ts src/lib/security/oauth-redirect.test.ts src/lib/leagues/league-social-links.test.ts src/lib/observability/security-log.test.ts src/lib/routing/legacy-route-redirects.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:tournaments": "node --experimental-strip-types --test src/lib/tournaments/score-quarters.test.ts",
    "db:phase2": "node scripts/phase2-db.mjs",
    "db:phase2:verify": "node scripts/phase2-db.mjs verify",
    "db:phase2:apply": "node scripts/phase2-db.mjs apply-all",
    "env:phase3:verify": "node scripts/phase3-env-check.mjs",
    "env:phase3:verify:strict": "node scripts/phase3-env-check.mjs --strict",
    "supabase:deploy:functions": "node scripts/deploy-supabase-edge-functions.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.11.0",
    "next": "16.2.6",
    "pdfjs-dist": "^4.10.38",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "react-icons": "^5.6.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  }
}
