{
  "name": "liga-basket-iquitos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true}); console.log('Removed .next')\"",
    "sync:dev-manifest": "node scripts/sync-dev-next-manifests.mjs",
    "dev": "node scripts/sync-dev-next-manifests.mjs && next dev -p 3001 --webpack",
    "dev:turbo": "next dev -p 3001 --turbopack",
    "dev:clean": "npm run clean && npm run dev",
    "dev:fresh": "npm run clean && npm run build && npm run dev",
    "build": "next build",
    "postbuild": "node scripts/sync-dev-next-manifests.mjs",
    "start": "next start -p 3001",
    "lint": "eslint",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "push": "drizzle-kit push",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.11.0",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "react-icons": "^5.6.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  }
}
