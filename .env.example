# Copiar a `.env.local` (DEV) — no commitear secretos.
# Producción: Vercel → Environment Variables (ref jfgnwtkmqayzhlwfxidz).
# Desarrollo: Supabase liga-iquitos-dev (ref txmnlszmumayyrisqeby).
# Guía: docs/environments-dev-prod.md
# Verificación: npm run env:verify  |  deploy: npm run env:verify:strict

# ─── Observabilidad (opcional) ───
# SECURITY_LOG_JSON=1
# SENTRY_DSN=

# ─── E2E Playwright (local / secretos CI) ───
# E2E_BASE_URL=http://localhost:3001
# E2E_DELEGATE_EMAIL=
# E2E_DELEGATE_PASSWORD=
# E2E_LEAGUE_SLUG=lddbi-iquitos
# E2E_FOREIGN_CLUB_ID=

# ─── Entorno ───
APP_ENV=development
SUPABASE_PROJECT_REF=txmnlszmumayyrisqeby

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://txmnlszmumayyrisqeby.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Hosts extra para OAuth Google (cliente + servidor), separados por coma
# NEXT_PUBLIC_AUTH_ALLOWED_REDIRECT_HOSTS=liga-basket-iquitos.vercel.app

# ─── Plataforma multi-liga (Fase 4) ───
PLATFORM_NAME=Plataforma de ligas
PLATFORM_DEFAULT_LEAGUE_SLUG=lddbi
# NEXT_PUBLIC_DEFAULT_LEAGUE_ID=

# ─── Rate limit distribuido (Fase 3 — Upstash / integración Vercel) ───
# Integración Vercel Upstash inyecta KV_REST_API_* (Production + Preview + Development).
# Redis.fromEnv() también acepta alias UPSTASH_REDIS_REST_*.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Local sin Redis (npm run dev): SECURITY_RATE_LIMIT_DISABLED=true o APP_ENV=development
# SECURITY_RATE_LIMIT_DISABLED=true

# ─── Stripe / Billing (Fase 6) ───
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# SIGNUP_ENABLED=true
# SIGNUP_INVITE_ONLY=false
# SIGNUP_INVITE_TOKEN=
# SIGNUP_ALLOWED_EMAIL_DOMAINS=

VALIDATION_TOKEN_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DATABASE_URL_DIRECT=
# Fase 5b — rol liga_app (runtime RLS; migraciones siguen con owner arriba)
# DATABASE_URL_APP=
# Staging Fase 2: USE_APP_DB_ROLE=true (lecturas con liga_app + JWT)
# Prod Fase 2c: USE_APP_DB_ROLE_WRITES=true (escrituras)
# Rollback BLQ-3.1d: ambos false en Vercel, sin redeploy
# USE_APP_DB_ROLE=false
# USE_APP_DB_ROLE_WRITES=false
# LIGA_APP_DB_PASSWORD=   # solo scripts/provision-liga-app-role.mjs (no commitear)
DATABASE_POOL_MAX=10

MASTER_SUPER_ADMIN_EMAIL=
# IPs permitidas para la cuenta maestra (coma-separadas). Vacío = sin restricción (dev local).
MASTER_SUPER_ADMIN_IP_ALLOWLIST=
SYSTEM_OWNER_EMAILS=

NEXT_PUBLIC_BUCKET_ASSETS=club-assets
NEXT_PUBLIC_BUCKET_PLAYERS=jugador-fotos
NEXT_PUBLIC_BUCKET_GALLERY=galeria
NEXT_PUBLIC_BUCKET_RECEIPTS=recibos-tesoreria
NEXT_PUBLIC_BUCKET_NORMATIVAS=normativas
